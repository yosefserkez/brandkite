# ──────────────────────────────────────────────────────────────────────────────
# Brandkite environment variables
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to `.env.local` for client-side / Vite variables and configure
# the remaining (server-side) variables in your Convex deployment via:
#
#     npx convex env set <NAME> <VALUE>
#
# Convex never reads from `.env.local`; only `VITE_*` and tooling variables do.
# See https://docs.convex.dev/production/environment-variables for details.
# ──────────────────────────────────────────────────────────────────────────────


# ── Vite / client (read at build time from .env.local) ───────────────────────

# Public Convex deployment URL. Created by `npx convex dev` on first run and
# written into `.env.local` for you. Example: https://acme-cat-123.convex.cloud
VITE_CONVEX_URL=

# Optional — Sentry browser SDK. Leave blank to disable client-side reporting.
VITE_SENTRY_DSN=
VITE_SENTRY_ENV=development

# Optional — overrides the document title in <head>.
VITE_APP_TITLE=Brandkite

# Optional — PostHog product analytics. Leave blank to disable all tracking.
# This is the public project API key (phc_...), safe to expose client-side.
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com


# ── Sentry source-map upload (build-time only, used by vite.config.ts) ───────
# Only needed when you want to upload source maps from CI. Safe to leave blank
# for local development.
VITE_SENTRY_ORG=
VITE_SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=


# ── Convex deployment (set via `npx convex env set ...`) ─────────────────────
# These are listed here for documentation — they belong in the Convex dashboard
# (or `convex env set`), NOT in `.env.local`.

# Public-facing URL Convex uses for auth callbacks. `npx convex dev` sets this
# automatically for the dev deployment.
# CONVEX_SITE_URL=

# Resend API key — used by @convex-dev/auth's Resend magic-link provider.
# Sign up at https://resend.com and verify the sending domain referenced in
# convex/auth.ts (default: mail.brandkite.co — change this if you fork).
# AUTH_RESEND_KEY=

# OpenRouter — text generation for every brand module (name, tagline, mission,
# vision, story, tone, colors, typography, ...). https://openrouter.ai
# OPENROUTER_API_KEY=

# OpenAI — only used to compute text embeddings for the logo vector search
# (convex/logoVectorSearch.ts). https://platform.openai.com
# OPENAI_API_KEY=

# Replicate — runs the logo image model (recraft-ai/recraft-20b-svg) and the
# CLIP image-embedding model. https://replicate.com
# REPLICATE_API_TOKEN=

# Firecrawl — scrapes a company URL to bootstrap brand context.
# https://www.firecrawl.dev
# FIRECRAWL_API_KEY=

# Cloudflare R2 — asset storage via @convex-dev/r2 (logos, uploaded images).
# Set these via `npx convex env set` in the Convex dashboard. See
# https://www.convex.dev/components/cloudflare-r2 for the full list of names
# the component expects (typically R2_TOKEN, R2_ACCESS_KEY_ID,
# R2_SECRET_ACCESS_KEY, R2_ENDPOINT, R2_BUCKET).
# R2_TOKEN=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_ENDPOINT=
# R2_BUCKET=

# Autumn — billing / usage metering. Optional; the UI degrades gracefully if
# the key is missing, but `useautumn` calls will fail. https://useautumn.com
# AUTUMN_SECRET_KEY=
